# Copy this file to ".env" in the project root for Docker/Dokploy.

FRONTEND_APP_ENV=production
FRONTEND_BASE_URL=https://your-domain.example
FRONTEND_BACKEND_URL=https://your-domain.example/backend
FRONTEND_SESSION_SECURE=true
FRONTEND_SESSION_SAMESITE=Lax
FRONTEND_ALLOW_DEV_ADMIN_LOGIN=false

BACKEND_APP_ENV=production
BACKEND_APP_DEBUG=false
BACKEND_APP_URL=https://your-domain.example/backend
BACKEND_APP_KEY=base64:GENERATE_THIS_WITH_PHP_ARTISAN_KEY_GENERATE
BACKEND_DB_CONNECTION=mysql
BACKEND_DB_HOST=db
BACKEND_DB_PORT=3306
BACKEND_DB_DATABASE=vehicleregistrationsystem
BACKEND_DB_USERNAME=root
BACKEND_DB_PASSWORD=replace_with_strong_password
BACKEND_CACHE_DRIVER=redis
BACKEND_SESSION_DRIVER=redis
BACKEND_SESSION_STORE=redis
BACKEND_SESSION_SECURE_COOKIE=true
BACKEND_SESSION_HTTP_ONLY=true
BACKEND_SESSION_SAME_SITE=lax
BACKEND_QUEUE_CONNECTION=redis
BACKEND_REDIS_HOST=redis
BACKEND_REDIS_PORT=6379
BACKEND_REDIS_PASSWORD=replace_with_strong_redis_password
BACKEND_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
BACKEND_LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
BACKEND_MUTATION_RATE_LIMIT_PER_MINUTE=120
BACKEND_API_RATE_LIMIT_PER_MINUTE=120
ALLOW_LEGACY_MUTATIONS=false
ALLOW_SAMPLE_SEEDING=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@your-domain.example
SEED_ADMIN_PASSWORD=

MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_DATABASE=vehicleregistrationsystem
MYSQL_USER=root
MYSQL_PASSWORD=replace_with_strong_password
REDIS_PASSWORD=replace_with_strong_redis_password
